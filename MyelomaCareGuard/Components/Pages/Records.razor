@page "/records"
@attribute [Authorize]

@using ApexCharts
@using MyelomaCareGuard.DTOs
@using MyelomaCareGuard.Models
@using Microsoft.AspNetCore.Components.Authorization
@using MyelomaCareGuard.Services
@using MyelomaCareGuard.Services.Interfaces

@inject AuthenticationStateProvider AuthStateProvider
@inject IRecordService RecordService
@inject IRecordMetadataService RecordMetadataService

<div class="records-header">
    <h2 class="page-title">Health Records</h2>
    <h6 class="page-subtitle">Track and view trends</h6>

    <!-- TYPE SELECTOR (chips style) -->
    <div class="chip-row">
        @foreach (var type in Enum.GetValues<RecordType>())
        {
            <button class="chip @(selectedType == type ? "active" : "")"
                    @onclick="() => SelectType(type)">
                @type
            </button>
        }
    </div>
</div>

<div class="records-scroll">
    <!-- TREND CARD -->
    <div class="card">

        <h4>@selectedType Trend</h4>

        @if (filteredRecords.Any())
        {
            <ApexChart TItem="ChartPoint"
                       Height="220"
                       @key="@($"{selectedType}-{Guid.NewGuid()}")">

                <ApexPointSeries TItem="ChartPoint"
                                 Name="@selectedType.ToString()"
                                 Items="chartData"
                                 XValue="@(e => e.Label)"
                                 YValue="@(e => e.Value)" />

            </ApexChart>

            <div class="range">
                Normal range: @meta.Min - @meta.Max @meta.Unit
            </div>
        }
        else
        {
            <p class="muted">No data yet</p>
        }

    </div>

    <!-- ADD RECORD -->
    <div class="card">
        <h4>Add Record</h4>

        <input class="form-control"
               type="number"
               placeholder="Enter value"
               @bind="value" />

        <button class="btn-primary mt-2" @onclick="AddRecord">
            + Add
        </button>
    </div>

    <!-- RECORD LIST -->
    <div class="card">
        <h4>Recent Records</h4>

        @foreach (var r in latestRecords)
        {
            <div class="record-item">

                <!-- LEFT -->
                <div class="record-left record-sub-item">

                    @if (editingRecordId == r.Id)
                    {
                        <input class="form-control"
                               type="number"
                               @bind="editValue" />
                    }
                    else
                    {
                        <div class="record-value">
                            @r.Value
                            <span class="record-unit">@meta.Unit</span>
                        </div>
                    }

                    <div class="record-date">
                        <i class="bi bi-calendar3"></i>
                        @r.Date.ToString("MMM dd, yyyy")
                    </div>
                </div>

                <!-- RIGHT -->
                <div class="record-right">

                    <span class="@GetStatusClass(r)">
                        @GetStatusText(r)
                    </span>

                    <div class="record-actions">

                        @if (editingRecordId == r.Id)
                        {
                            <button class="icon-btn save"
                                    @onclick="() => SaveEdit(r)">
                                <i class="bi bi-check-lg"></i>
                            </button>

                            <button class="icon-btn cancel"
                                    @onclick="CancelEdit">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        }
                        else
                        {
                            <button class="icon-btn edit"
                                    @onclick="() => StartEdit(r)">
                                <i class="bi bi-pencil"></i>
                            </button>

                            <button class="icon-btn delete"
                                    @onclick="() => DeleteRecord(r.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        }

                    </div>

                </div>

            </div>
        }
    </div>
</div>




@code {
    private RecordType selectedType = RecordType.MProtein;
    private decimal value;

    private List<Record> records = new();

    private int? editingRecordId = null;

    private decimal editValue;

    private IEnumerable<Record> filteredRecords =>
        records
            .Where(r => r.Type == selectedType)
            .Where(r => r.Date >= DateTime.Now.AddYears(-1))
            .OrderBy(r => r.Date);

    private IEnumerable<Record> latestRecords =>
    records
        .Where(r => r.Type == selectedType)
        .OrderByDescending(r => r.Date)
        .Take(20);

    private List<ChartPoint> chartData =>
        filteredRecords
            .OrderBy(x => x.Date)
            .Select(x => new ChartPoint
            {
                Label = x.Date.ToString("MM-dd HH:mm:ss"),
                Value = (decimal)x.Value
            })
            .ToList();

    private RecordMetadata meta => RecordMetadataService.GetMetadata(selectedType);

    protected override async Task OnInitializedAsync()
    {
        await LoadRecords();
    }

    private async Task LoadRecords()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        records = await RecordService.GetByUserAsync(userId);
    }

    private async Task AddRecord()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        var record = new Record
        {
            Type = selectedType,
            Value = (double)value,
            UserId = userId,
            Date = DateTime.Now
        };

        await RecordService.AddAsync(record);
        await LoadRecords();

        value = 0;
    }

    private void SelectType(RecordType type)
    {
        selectedType = type;

        InvokeAsync(() =>
        {
            StateHasChanged();
        });
    }

    private string GetStatusClass(Record r)
    {
        if (r.Value > meta.Max) return "status high";
        if (r.Value < meta.Min) return "status low";
        return "status normal";
    }

    private string GetStatusText(Record r)
    {
        if (r.Value > meta.Max) return "High";
        if (r.Value < meta.Min) return "Low";
        return "Normal";
    }

    private void StartEdit(Record r)
    {
        editingRecordId = r.Id;
        editValue = (decimal)r.Value;
    }

    private void CancelEdit()
    {
        editingRecordId = null;
    }

    private async Task SaveEdit(Record r)
    {
        r.Value = (double)editValue;

        await RecordService.UpdateAsync(r);

        editingRecordId = null;

        await LoadRecords();
    }

    private async Task DeleteRecord(int id)
    {
        await RecordService.DeleteAsync(id);

        await LoadRecords();
    }
}